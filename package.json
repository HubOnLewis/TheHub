{
  "name": "the-hub-crm",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "docker-compose up",
    "dev:api": "npm run dev --workspace=packages/api",
    "dev:web": "npm run dev --workspace=packages/web",
    "build": "npm run build --workspaces --if-present",
    "build:render:web": "node scripts/render-prepare-web-build.mjs",
    "verify:web-env": "node scripts/verify-web-env.mjs --strict",
    "verify:deploy": "node scripts/verify-deploy-readiness.mjs",
    "smoke:production": "node scripts/smoke-production.mjs",
    "smoke:cors": "node scripts/smoke-cors.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "extract:perfect-venue": "node scripts/extract-perfect-venue.mjs",
    "import:perfect-venue": "node scripts/import-perfect-venue-export.mjs",
    "import:pfevents": "node scripts/import-pfevents-txt.mjs",
    "import:pfevents:apply": "node scripts/import-pfevents-txt.mjs --apply",
    "validate:crm-events": "node scripts/validate-crm-event-source.mjs",
    "audit:hub-contamination": "node scripts/hub-contamination.mjs",
    "cleanup:hub-contamination": "node scripts/hub-contamination.mjs --apply",
    "reset:hub-data:audit": "node scripts/reset-hub-tenant-data.mjs --audit",
    "reset:hub-data:dry-run": "node scripts/reset-hub-tenant-data.mjs --dry-run",
    "reset:hub-data:apply": "node scripts/reset-hub-tenant-data.mjs --apply",
    "import:hub-refresh:audit": "node scripts/import-hub-refresh.mjs --audit",
    "import:hub-refresh:dry-run": "node scripts/import-hub-refresh.mjs --dry-run",
    "import:hub-refresh:apply": "node scripts/import-hub-refresh.mjs --apply --confirm-production",
    "audit:hub-prod-data": "node scripts/audit-hub-prod-data.mjs",
    "probe:mongo": "node scripts/mongo-db-probe.mjs",
    "copy:hub-refresh-data:dry-run": "node scripts/copy-hub-refresh-data.mjs",
    "copy:hub-refresh-data:apply": "node scripts/copy-hub-refresh-data.mjs --apply",
    "repair:hub-refresh-tenant:dry-run": "node scripts/repair-hub-refresh-tenant.mjs",
    "repair:hub-refresh-tenant:apply": "node scripts/repair-hub-refresh-tenant.mjs --apply",
    "reset:all-passwords:dry-run": "node scripts/reset-all-user-passwords.mjs",
    "reset:all-passwords:apply": "node scripts/reset-all-user-passwords.mjs --apply --confirm",
    "validate:hub-refresh": "node scripts/validate-hub-refresh.mjs",
    "postinstall:playwright": "playwright install chromium"
  },
  "devDependencies": {
    "playwright": "^1.49.1",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "csv-parse": "^5.6.0",
    "xlsx": "^0.18.5"
  }
}
