# packages/web — Vite environment (local development)
# Copy to packages/web/.env.local or set in repo root .env (Vite loads from project root too).

# Local dev — omit to use Vite proxy (/api → http://localhost:3001)
# VITE_API_URL=http://localhost:3001/api

# Production (Render static site — REQUIRED, baked in at build time)
# Set on the The-Hub static site in Render Dashboard:
#   VITE_API_URL=https://the-hub-api.onrender.com/api
#
# Custom API domain example:
#   VITE_API_URL=https://api.hubonlewis.com/api
#
# Never use localhost in production builds — Render build will fail.
