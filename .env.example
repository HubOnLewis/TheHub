# .env — local development (native Node)
# Copy this file to .env and fill in your values.
# Not needed when using docker-compose (values are inline there).

NODE_ENV=development
PORT=3001

# MongoDB — option A: local install (default port)
MONGODB_URI=mongodb://localhost:27017/mtte_core
DB_NAME=mtte_core

# MongoDB — option B: Atlas free tier
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/mtte_core?retryWrites=true&w=majority

# Must be at least 32 characters
JWT_SECRET=change_this_to_a_secure_random_string_32chars

# Vite dev server (web package)
CLIENT_URL=http://localhost:5173

# Comma-separated list — these accounts bypass all tenant scoping
SUPER_ADMIN_EMAILS=mike@wki.com

# Attachment storage abstraction (local now; S3-ready config)
ATTACHMENT_STORAGE_DRIVER=local
ATTACHMENT_S3_BUCKET=
ATTACHMENT_S3_REGION=
ATTACHMENT_S3_BASE_URL=
