# .env — local development (native Node)
# Copy this file to .env and fill in your values.
# Not needed when using docker-compose (values are inline there).

NODE_ENV=development
PORT=3001

# MongoDB — DB_NAME must match the database segment in MONGODB_URI.
#
# New installs: use hub_crm (and a URI that targets that database).
# Legacy environments may use another database name — keep DB_NAME and URI aligned.
# Changing DB_NAME without migrating data points the API at an empty database.
MONGODB_URI=mongodb://localhost:27017/hub_crm
DB_NAME=hub_crm

# MongoDB — Atlas example
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/hub_crm?retryWrites=true&w=majority

# Must be at least 32 characters
JWT_SECRET=change_this_to_a_secure_random_string_32chars

# Local dev — Vite default origin (also auto-allowed when NODE_ENV=development)
CLIENT_URL=http://localhost:5173

# API CORS — comma-separated browser origins (production Render API service)
# CORS_ORIGINS=https://admin.hubonlewis.com,https://the-hub-qy8a.onrender.com,http://localhost:5173,http://127.0.0.1:5173

# Comma-separated — super-admin bypass for tenant scoping (HuB operator demo)
SUPER_ADMIN_EMAILS=jason@hubonlewis.com,hannah@hubonlewis.com,jaden@hubonlewis.com

# Render Blueprint — auto-derived public URLs when CLIENT_URL / VITE_API_URL are unset
# HUB_WEB_SERVICE_NAME=The-Hub
# HUB_API_SERVICE_NAME=The-Hub-Api
# RENDER_ONRENDER_ROOT=onrender.com

# --- Optional: seed-admin.mjs overrides (local/dev only — never production secrets) ---
# SEED_ADMIN_NAME=Jason Lavender
# SEED_ADMIN_EMAIL=admin@hubonlewis.com
# SEED_ADMIN_PASSWORD=HubAdmin123!
# SEED_ADMIN_ENTITY=HUB
# SEED_ADMIN_LOCATION=Wichita
# SEED_ADMIN_TENANT_ID=hub-wichita

# Attachment storage abstraction (local now; S3-ready config)
ATTACHMENT_STORAGE_DRIVER=local
ATTACHMENT_S3_BUCKET=
ATTACHMENT_S3_REGION=
ATTACHMENT_S3_BASE_URL=

# --- Web (Vite) — optional for local dev; REQUIRED on Render static site ---
# Local: leave unset to use relative `/api` (proxied to localhost:3001 in dev).
# Production (Render The-Hub static site): MUST be set before build — baked into the bundle.
#   VITE_API_URL=https://the-hub-api.onrender.com/api
# If you set this locally, it MUST include `/api` (Express mounts routes under /api).
# VITE_API_URL=http://localhost:3001/api
#
# Legacy-adapted modules (bookings, fulfillment, closeout, proposals/builds). When unset:
#   - Vite dev: defaults ON so local workflows keep working
#   - production build: defaults OFF for client-safe demos (set true to enable)
# VITE_FEATURE_BOOKINGS=true
# VITE_FEATURE_FULFILLMENT=true
# VITE_FEATURE_CLOSEOUT=true
# VITE_FEATURE_BUILDS=true
# VITE_FEATURE_LEGACY_IMPORTS_UI=false
#
# --- Intelligence (rules-first; LLM optional) ---
# VITE_AI_PROVIDER=none
# VITE_AI_MODE=off
# AI_PROVIDER=none
# AI_MODE=off

# --- Google Analytics 4 (web / Vite) ---
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Mailchimp (API — optional; service no-ops when unset) ---
# MAILCHIMP_API_KEY=
# MAILCHIMP_SERVER_PREFIX=us21
# MAILCHIMP_AUDIENCE_ID=

# Auth: the web app may read legacy storage keys once to migrate sessions to hub_crm_token — intentional for upgrades.
